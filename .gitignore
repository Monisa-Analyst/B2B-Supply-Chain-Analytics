# Git Ignore Rules

# Block all data files containing potential transactional records
*.csv
*.pbix
*.xlsx
*.xls
*Anand_Engineering*

# Exclude sample data file from ignore list so it can be uploaded
!data/sample_data.csv

# Block scripts and mapping logs from repository
scripts/

# Local Development / Notebooks
.ipynb_checkpoints/
__pycache__/
*.log
*.metadata.json

# Operating System
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
